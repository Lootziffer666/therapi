+import argparse
+import json
+import time
+import urllib.parse
+import urllib.request
+from dataclasses import dataclass
+from pathlib import Path
+from typing import Any
+
+
+@dataclass
+class ListenerTarget:
- url: str
- method: str = "GET"
- headers: dict[str, str] | None = None
- json\_body: Any | None = None
- name: str | None = None
-
-
+def load\_targets(path: str) -> list[ListenerTarget]:
- payload = json.loads(Path(path).read\_text(encoding="utf-8"))
- raw\_targets = payload["targets"] if isinstance(payload, dict) else payload
- targets: list[ListenerTarget] = []
- for item in raw\_targets:
-   if not isinstance(item, dict):
-       continue
-   url = str(item.get("url", "")).strip()
-   if not url:
-       continue
-   targets.append(
-       ListenerTarget(
-           url=url,
-           method=str(item.get("method", "GET")).upper(),
-           headers=item.get("headers"),
-           json\_body=item.get("json"),
-           name=item.get("name"),
-       )
-   )
- return targets
-
-
+def run\_once(
- proxy\_base\_url: str,
- targets: list[ListenerTarget],
- timeout\_sec: float = 15.0,
+) -> list[dict[str, Any]]:
- base = proxy\_base\_url.rstrip("/")
- results: list[dict[str, Any]] = []
- for target in targets:
-   encoded\_url = urllib.parse.quote(target.url, safe="")
-   proxy\_url = f"{base}/?url={encoded\_url}"
-   body: bytes | None = None
-   if target.json\_body is not None:
-       body = json.dumps(target.json\_body).encode("utf-8")
-   request = urllib.request.Request(
-       url=proxy\_url,
-       method=target.method,
-       data=body,
-       headers=target.headers or {},
-   )
-   if body is not None and "Content-Type" not in request.headers:
-       request.add\_header("Content-Type", "application/json")
-
-   started = time.time()
-   try:
-       with urllib.request.urlopen(request, timeout=timeout\_sec) as response:
-           status = response.status
-           response.read()
-       results.append(
-           {
-               "name": target.name or target.url,
-               "method": target.method,
-               "url": target.url,
-               "status": status,
-               "ok": 200 <= status < 500,
-               "duration\_ms": int((time.time() - started) * 1000),
-               "error": None,
-           }
-       )
-   except Exception as err: \# noqa: BLE001
-       results.append(
-           {
-               "name": target.name or target.url,
-               "method": target.method,
-               "url": target.url,
-               "status": None,
-               "ok": False,
-               "duration\_ms": int((time.time() - started) * 1000),
-               "error": str(err),
-           }
-       )
- return results
-
-
+def main() -> None:
- parser = argparse.ArgumentParser(description="therAPI auto listener/replay helper")
- parser.add\_argument("--proxy-base-url", default="[http://127.0.0.1:8080](http://127.0.0.1:8080)")
- parser.add\_argument("--targets-file", required=True)
- parser.add\_argument("--interval-sec", default=60.0, type=float)
- parser.add\_argument("--cycles", default=1, type=int, help="0 = infinite loop")
- parser.add\_argument("--timeout-sec", default=15.0, type=float)
- parser.add\_argument("--report-file", default=".therapi/autolistener\_report.jsonl")
- args = parser.parse\_args()
-
- targets = load\_targets(args.targets\_file)
- if not targets:
- raise SystemExit("No valid targets found in targets-file.")
-
- report\_path = Path(args.report\_file)
- report\_path.parent.mkdir(parents=True, exist\_ok=True)
-
- cycle = 0
- while True:
- cycle += 1
- timestamp = time.strftime("%Y-%m-%dT%H:%M:%SZ", time.gmtime())
- results = run\_once(
- proxy\_base\_url=args.proxy\_base\_url,
- targets=targets,
- timeout\_sec=args.timeout\_sec,
- )
- ok\_count = sum(1 for item in results if item["ok"])
- print(f"[{timestamp}] cycle={cycle} ok={ok\_count}/{len(results)}")
- for item in results:
- status = item["status"] if item["status"] is not None else "-"
- name = item["name"]
- duration = item["duration\_ms"]
- err = f" error={item['error']}" if item["error"] else ""
- print(f" - {status} {name} ({duration}ms){err}")
-
- with report\_path.open("a", encoding="utf-8") as handle:
- handle.write(
- json.dumps(
- {
- "ts": timestamp,
- "cycle": cycle,
- "results": results,
- }
- )
- + "\n"
- )
-
- if args.cycles > 0 and cycle >= args.cycles:
- break
- time.sleep(args.interval\_sec)
-
-
+if name == "main":
- main()
-

